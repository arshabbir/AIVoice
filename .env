# App settings
APP_HOST=0.0.0.0
APP_PORT=8080
APP_BASE_URL=http://app:8080
UPLOAD_DIR=/data/uploads
APP_DB_PATH=/data/app.db
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=knowledge_base
EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
SEARCH_TOP_K=2
RAG_CONFIDENCE_THRESHOLD=0.16
ANSWER_MODE=hybrid
AGENT_LOG_LEVEL=DEBUG
APP_LOG_LEVEL=INFO
SPEECH_LOG_LEVEL=DEBUG

# Agent settings
OLLAMA_BASE_URL=http://ollama:11434/v1
OLLAMA_MODEL=qwen2.5:3B
OLLAMA_TEMPERATURE=0.2
SPEECH_BASE_URL=http://speech:8001/v1
SPEECH_API_KEY=local-speech-key
STT_MODEL=whisper-1
TTS_MODEL=kokoro
KOKORO_VOICE=af_heart
GREETING_TEXT="Hello. How can I help you?."
MAX_AGENT_CONCURRENCY=1

# Ollama concurrency tuning
OLLAMA_NUM_PARALLEL=1
OLLAMA_MAX_LOADED_MODELS=1
OLLAMA_MAX_QUEUE=8
OLLAMA_CONTEXT_LENGTH=1024
OLLAMA_PULL_ON_START=true

# Whisper/Kokoro service
WHISPER_MODEL=tiny.en
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
KOKORO_LANG_CODE=a
KOKORO_DEFAULT_VOICE=af_heart
PRELOAD_WHISPER=true
PRELOAD_KOKORO=true

# GPU placement
OLLAMA_GPU=
SPEECH_GPU=

CHUNK_SIZE=700
CHUNK_OVERLAP=120
QDRANT_UPSERT_BATCH_SIZE=64
QDRANT_MAX_REQUEST_BYTES=29360128
EMBED_BATCH_SIZE=64
